# Google Gemini (required for ADK agents) — Google AI Studio, not Vertex.
# Create a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Use Google AI API (Gemini developer API) with GOOGLE_API_KEY — do not use Vertex.
GOOGLE_GENAI_USE_VERTEXAI=false

# Optional: override default Gemini model
# GEMINI_MODEL=gemini-2.5-flash

# Kalshi Trade API — default is DEMO (no key needed for public httpx tools).
# Production example: https://api.elections.kalshi.com/trade-api/v2
KALSHI_TRADE_API_BASE=https://demo-api.kalshi.co/trade-api/v2

# Authenticated SDK tools (kalshi-python-sync): Key ID + RSA private key PEM.
# Generate keys in the Kalshi account dashboard (demo vs prod matches KALSHI_TRADE_API_BASE).
KALSHI_API_KEY_ID=
# Path to PEM file, or leave empty and use KALSHI_PRIVATE_KEY_PEM instead.
KALSHI_PRIVATE_KEY_PATH=
# Raw PEM string (optional alternative to KALSHI_PRIVATE_KEY_PATH). Use \n for newlines in .env if needed.
# KALSHI_PRIVATE_KEY_PEM=

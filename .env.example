# =============================================================================
# ProbDesk — copy to .env at the repo root (never commit .env)
# =============================================================================

# --- Required: Google Gemini (ADK agents) ---
# Create a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Use the Gemini Developer API (not Vertex)
GOOGLE_GENAI_USE_VERTEXAI=false

# Optional model override (must support tools / google_search if used)
# GEMINI_MODEL=gemini-2.5-flash

# --- Kalshi Trade API ---
# Demo (default): public market data works without keys
KALSHI_TRADE_API_BASE=https://demo-api.kalshi.co/trade-api/v2

# Production example (must match your key environment):
# KALSHI_TRADE_API_BASE=https://api.elections.kalshi.com/trade-api/v2

# Authenticated SDK tools (balance, positions, orders, execution)
# Demo setup slides: https://docs.google.com/presentation/d/e/2PACX-1vRvhUAqRBYzJmt7JCinMXmu6KVWkj-cc7ikDXGConmqjcv4mnlJacgHPcZJ20fWWnrYdubn-oczclKP/pub?start=false&loop=false&delayms=3000&slide=id.g359756fc63c_5_25
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi/private_key.pem
# Or inline PEM (use \n for newlines in .env):
# KALSHI_PRIVATE_KEY_PEM=

# --- CopilotKit web UI (optional overrides) ---
# AG-UI backend URL (default when running `cd ui && npm run dev`)
# PROB_DESK_AGUI_URL=http://127.0.0.1:8000/

# Optional MCP Apps in the CopilotKit sidebar
# PROB_DESK_MCP_APPS_URL=
# PROB_DESK_MCP_APPS_SERVER_ID=

# --- Optional: AgentPhone (voice / SMS via MCP) ---
# https://agentphone.to
# AGENTPHONE_API_KEY=

# --- CLI verbosity (optional) ---
# PROB_DESK_VERBOSE=0
